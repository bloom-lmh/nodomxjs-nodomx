{
  "name": "nodomx-nd-vscode",
  "displayName": "NodomX ND",
  "description": "VSCode support for NodomX .nd single-file components.",
  "version": "0.1.0",
  "publisher": "bloom-lmh",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://gitee.com/bloom_lmh/nodomx.git"
  },
  "files": [
    "dist",
    "language-configuration.json",
    "syntaxes",
    "snippets",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:nd",
    "onCommand:nodomx.compileCurrentNdFile"
  ],
  "main": "./dist/extension.cjs",
  "contributes": {
    "languages": [
      {
        "id": "nd",
        "aliases": [
          "NodomX ND",
          "nd"
        ],
        "extensions": [
          ".nd"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "nd",
        "scopeName": "source.nd",
        "path": "./syntaxes/nd.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "nodomx.compileCurrentNdFile",
        "title": "NodomX: Compile Current .nd File"
      }
    ],
    "configuration": {
      "title": "NodomX ND",
      "properties": {
        "nodomx.nd.importSource": {
          "type": "string",
          "default": "",
          "description": "Optional import source used when compiling .nd files. Leave empty to infer from the nearest package.json name."
        },
        "nodomx.nd.compileOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Automatically compile .nd files to sibling generated modules whenever a file is saved."
        },
        "nodomx.nd.enableLanguageServer": {
          "type": "boolean",
          "default": true,
          "description": "Enable semantic completions, diagnostics, and go-to-definition for .nd files."
        },
        "nodomx.nd.outputSuffix": {
          "type": "string",
          "default": ".nd.gen.mjs",
          "description": "Suffix appended to compiled .nd files."
        }
      }
    },
    "snippets": [
      {
        "language": "nd",
        "path": "./snippets/nd.json"
      }
    ]
  },
  "scripts": {
    "build": "node ./scripts/build.cjs",
    "test": "node ./scripts/test.cjs",
    "package": "node ./scripts/package.cjs"
  },
  "dependencies": {},
  "devDependencies": {
    "@nodomx/nd-compiler": "0.1.0",
    "@vscode/vsce": "^3.6.2",
    "esbuild": "^0.25.1",
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.11"
  }
}
