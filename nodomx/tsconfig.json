{
  "strict":true,
  "compileOnSave": false,
  "compilerOptions": {
    "module":"esnext",
    "target": "ES2015",
    "baseUrl": ".",
    "lib": [
      "es5",
      "es6",
      "dom",
      "ES2017"
    ],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "outDir":"./dist",
    "sourceMap": true,
    "moduleResolution": "node",
    "declaration": true,
    "declarationDir":"./dist/types",
    "paths": {
      "@nodomx/core": [
        "./packages/core/src/index.ts"
      ]
    }
  },
  "include":[
    "index.ts",
    "extend/**/*.ts"
  ],
  "exclude": [
    "./examples"
  ]
}
