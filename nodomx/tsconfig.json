{
  "extends": "./tsconfig.package-base.json",
  "strict": true,
  "compileOnSave": false,
  "compilerOptions": {
    "target": "ES2015",
    "lib": [
      "es5",
      "es6",
      "dom",
      "ES2017"
    ],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "outDir": "./dist",
    "declarationDir": "./dist/types"
  },
  "include":[
    "index.ts",
    "extend/**/*.ts"
  ],
  "exclude": [
    "./examples"
  ]
}
