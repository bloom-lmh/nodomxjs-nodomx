{
  "name": "nodomx",
  "version": "0.2.3",
  "private": false,
  "type": "module",
  "main": "./dist/nodom.esm.js",
  "exports": {
    ".": {
      "import": "./dist/nodom.esm.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "npm run test:composition && npm run test:hmr && npm run test:optimize && npm run test:list && npm run test:router && npm run test:router-preload",
    "test:smoke": "npm run test:composition",
    "test:composition": "node ./tests/composition.smoke.mjs",
    "test:hmr": "node ./tests/hmr.smoke.mjs",
    "test:optimize": "node ./tests/render-optimize.smoke.mjs",
    "test:list": "node ./tests/list-diff.smoke.mjs",
    "test:router": "node ./tests/router.smoke.mjs",
    "test:router-preload": "node ./tests/router-preload.smoke.mjs",
    "build": "node ./scripts/clean-dist.mjs && rollup -c rollup.config.mjs && node ./scripts/trim-dist.mjs",
    "watch": "rollup -c rollup.config.mjs -w"
  },
  "author": "weblabsw",
  "license": "MIT",
  "unpkg": "dist/nodom.esm.min.js",
  "module": "dist/nodom.esm.js",
  "types": "dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://gitee.com/bloom_lmh/nodomx.git",
    "directory": "nodomx"
  },
  "keywords": [
    "nodomx",
    "typescript",
    "javascript",
    "mvvm",
    "web"
  ],
  "bugs": {
    "url": "https://gitee.com/bloom_lmh/nodomx/issues"
  },
  "homepage": "https://gitee.com/bloom_lmh/nodomx",
  "description": "NodomX MVVM framework for building SPA applications.",
  "dependencies": {
    "@nodomx/reactivity": "^0.2.3",
    "@nodomx/runtime-core": "^0.2.3"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.2",
    "@rollup/plugin-node-resolve": "^15.1.0",
    "@rollup/plugin-terser": "^1.0.0",
    "@types/node": "^24.1.0",
    "jsdom": "^29.0.1",
    "rollup": "^3.26.0",
    "rollup-plugin-typescript2": "^0.35.0"
  }
}
