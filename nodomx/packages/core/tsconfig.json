{
  "compilerOptions": {
    "strict": false,
    "module": "esnext",
    "target": "ES2015",
    "lib": [
      "es5",
      "es6",
      "dom",
      "ES2017"
    ],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "outDir": "./dist",
    "sourceMap": true,
    "moduleResolution": "node",
    "declaration": true,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.ts"
  ]
}
