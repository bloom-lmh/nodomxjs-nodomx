{
  "name": "@nodomx/core",
  "version": "0.2.3",
  "description": "Core runtime primitives for the NodomX MVVM framework.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bloom-lmh/nodomxjs-nodomx.git",
    "directory": "nodomx/packages/core"
  },
  "homepage": "https://github.com/bloom-lmh/nodomxjs-nodomx",
  "bugs": {
    "url": "https://github.com/bloom-lmh/nodomxjs-nodomx/issues"
  },
  "keywords": [
    "nodomx",
    "core",
    "mvvm",
    "runtime"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "node ./scripts/clean-dist.mjs && node ./scripts/build-dist.mjs",
    "test": "npm run build"
  },
  "dependencies": {
    "@nodomx/reactivity": "^0.2.3",
    "@nodomx/runtime-core": "^0.2.3"
  },
  "devDependencies": {
    "typescript": "^5.9.2"
  }
}

