{
  "name": "nodomx-workspace",
  "private": true,
  "workspaces": [
    "nodomx",
    "nd-compiler",
    "rollup-plugin-nd",
    "rollup-plugin-dev-server",
    "create-nodomx",
    "vscode-extension"
  ],
  "scripts": {
    "build": "npm run build -w nodom3",
    "build:nd": "npm run build -w @nodomx/nd-compiler",
    "build:nd:rollup": "npm run build -w @nodomx/rollup-plugin-nd",
    "build:dev-server": "npm run build -w @nodomx/rollup-plugin-dev-server",
    "build:create": "npm run build -w create-nodomx",
    "build:vscode": "npm run build -w nodomx-nd-vscode",
    "build:all": "npm run build && npm run build:nd && npm run build:nd:rollup && npm run build:dev-server && npm run build:create && npm run build:vscode",
    "watch": "npm run watch -w nodom3",
    "watch:nd": "node ./nd-compiler/bin/ndc.mjs ./nodomx/examples --watch",
    "compile:nd": "node ./nd-compiler/bin/ndc.mjs",
    "test": "npm run test -w nodom3",
    "test:smoke": "npm run test:smoke -w nodom3",
    "test:composition": "npm run test:composition -w nodom3",
    "test:hmr": "npm run test:hmr -w nodom3",
    "test:nd": "npm run test -w @nodomx/nd-compiler",
    "test:nd:rollup": "npm run test -w @nodomx/rollup-plugin-nd",
    "test:dev-server": "npm run test -w @nodomx/rollup-plugin-dev-server",
    "test:create": "npm run test -w create-nodomx",
    "test:vscode": "npm run test -w nodomx-nd-vscode",
    "test:all": "npm run test && npm run test:nd && npm run test:nd:rollup && npm run test:dev-server && npm run test:create && npm run test:vscode",
    "pack:nd": "npm pack -w @nodomx/nd-compiler",
    "pack:nd:rollup": "npm pack -w @nodomx/rollup-plugin-nd",
    "pack:dev-server": "npm pack -w @nodomx/rollup-plugin-dev-server",
    "pack:create": "npm pack -w create-nodomx",
    "release:preflight": "node ./scripts/release/preflight.mjs",
    "release:version": "node ./scripts/release/version.mjs",
    "release:changelog": "node ./scripts/release/changelog.mjs",
    "release:check": "npm run build:all && npm run test:all && npm run pack:nd && npm run pack:nd:rollup && npm run pack:dev-server && npm run pack:create",
    "release:publish": "node ./scripts/release/publish.mjs",
    "package:extension": "npm run package -w nodomx-nd-vscode"
  }
}
