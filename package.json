{
  "name": "nodomx-workspace",
  "private": true,
  "workspaces": [
    "nodomx/packages/reactivity",
    "nodomx/packages/shared",
    "nodomx/packages/runtime-registry",
    "nodomx/packages/runtime-template",
    "nodomx/packages/runtime-optimize",
    "nodomx/packages/runtime-module",
    "nodomx/packages/runtime-view",
    "nodomx/packages/runtime-router",
    "nodomx/packages/runtime-scheduler",
    "nodomx/packages/runtime-app",
    "nodomx/packages/runtime-core",
    "nodomx/packages/core",
    "nodomx",
    "nd-compiler",
    "rollup-plugin-nd",
    "rollup-plugin-dev-server",
    "create-nodomx",
    "vscode-extension"
  ],
  "scripts": {
    "build": "npm run build:shared && npm run build:reactivity && npm run build:runtime-registry && npm run build:runtime-template && npm run build:runtime-optimize && npm run build:runtime-scheduler && npm run build:runtime-view && npm run build:runtime-module && npm run build:runtime-router && npm run build:runtime-app && npm run build:runtime-core && npm run build:core && npm run build -w nodomx",
    "build:shared": "npm run build -w @nodomx/shared",
    "build:reactivity": "npm run build -w @nodomx/reactivity",
    "build:runtime-registry": "npm run build -w @nodomx/runtime-registry",
    "build:runtime-template": "npm run build -w @nodomx/runtime-template",
    "build:runtime-optimize": "npm run build -w @nodomx/runtime-optimize",
    "build:runtime-module": "npm run build -w @nodomx/runtime-module",
    "build:runtime-view": "npm run build -w @nodomx/runtime-view",
    "build:runtime-router": "npm run build -w @nodomx/runtime-router",
    "build:runtime-scheduler": "npm run build -w @nodomx/runtime-scheduler",
    "build:runtime-app": "npm run build -w @nodomx/runtime-app",
    "build:runtime-core": "npm run build -w @nodomx/runtime-core",
    "build:core": "npm run build -w @nodomx/core",
    "build:nd": "npm run build -w @nodomx/nd-compiler",
    "build:nd:rollup": "npm run build -w @nodomx/rollup-plugin-nd",
    "build:dev-server": "npm run build -w @nodomx/rollup-plugin-dev-server",
    "build:create": "npm run build -w create-nodomx",
    "build:vscode": "npm run build -w nodomx-nd-vscode",
    "build:all": "npm run build && npm run build:nd && npm run build:nd:rollup && npm run build:dev-server && npm run build:create && npm run build:vscode",
    "watch": "npm run watch -w nodomx",
    "watch:nd": "node ./nd-compiler/bin/ndc.mjs ./nodomx/examples --watch",
    "compile:nd": "node ./nd-compiler/bin/ndc.mjs",
    "test": "npm run test:shared && npm run test:reactivity && npm run test:runtime-registry && npm run test:runtime-template && npm run test:runtime-optimize && npm run test:runtime-scheduler && npm run test:runtime-view && npm run test:runtime-module && npm run test:runtime-router && npm run test:runtime-app && npm run test:runtime-core && npm run test:core && npm run test -w nodomx",
    "test:shared": "npm run test -w @nodomx/shared",
    "test:reactivity": "npm run test -w @nodomx/reactivity",
    "test:runtime-registry": "npm run test -w @nodomx/runtime-registry",
    "test:runtime-template": "npm run test -w @nodomx/runtime-template",
    "test:runtime-optimize": "npm run test -w @nodomx/runtime-optimize",
    "test:runtime-module": "npm run test -w @nodomx/runtime-module",
    "test:runtime-view": "npm run test -w @nodomx/runtime-view",
    "test:runtime-router": "npm run test -w @nodomx/runtime-router",
    "test:runtime-scheduler": "npm run test -w @nodomx/runtime-scheduler",
    "test:runtime-app": "npm run test -w @nodomx/runtime-app",
    "test:runtime-core": "npm run test -w @nodomx/runtime-core",
    "test:core": "npm run test -w @nodomx/core",
    "test:smoke": "npm run test:smoke -w nodomx",
    "test:composition": "npm run test:composition -w nodomx",
    "test:hmr": "npm run test:hmr -w nodomx",
    "test:optimize": "npm run test:optimize -w nodomx",
    "test:list": "npm run test:list -w nodomx",
    "test:router": "npm run test:router -w nodomx",
    "test:router-preload": "npm run test:router-preload -w nodomx",
    "test:nd": "npm run test -w @nodomx/nd-compiler",
    "test:nd:rollup": "npm run test -w @nodomx/rollup-plugin-nd",
    "test:dev-server": "npm run test -w @nodomx/rollup-plugin-dev-server",
    "test:create": "npm run test -w create-nodomx",
    "test:vscode": "npm run test -w nodomx-nd-vscode",
    "test:all": "npm run test && npm run test:nd && npm run test:nd:rollup && npm run test:dev-server && npm run test:create && npm run test:vscode",
    "pack:shared": "npm pack -w @nodomx/shared",
    "pack:reactivity": "npm pack -w @nodomx/reactivity",
    "pack:runtime-registry": "npm pack -w @nodomx/runtime-registry",
    "pack:runtime-template": "npm pack -w @nodomx/runtime-template",
    "pack:runtime-optimize": "npm pack -w @nodomx/runtime-optimize",
    "pack:runtime-module": "npm pack -w @nodomx/runtime-module",
    "pack:runtime-view": "npm pack -w @nodomx/runtime-view",
    "pack:runtime-router": "npm pack -w @nodomx/runtime-router",
    "pack:runtime-scheduler": "npm pack -w @nodomx/runtime-scheduler",
    "pack:runtime-app": "npm pack -w @nodomx/runtime-app",
    "pack:runtime-core": "npm pack -w @nodomx/runtime-core",
    "pack:core": "npm pack -w @nodomx/core",
    "pack:nodomx": "npm pack -w nodomx",
    "pack:nd": "npm pack -w @nodomx/nd-compiler",
    "pack:nd:rollup": "npm pack -w @nodomx/rollup-plugin-nd",
    "pack:dev-server": "npm pack -w @nodomx/rollup-plugin-dev-server",
    "pack:create": "npm pack -w create-nodomx",
    "release:preflight": "node ./scripts/release/preflight.mjs",
    "release:version": "node ./scripts/release/version.mjs",
    "release:changelog": "node ./scripts/release/changelog.mjs",
    "release:check": "npm run build:all && npm run test:all && npm run pack:shared && npm run pack:reactivity && npm run pack:runtime-registry && npm run pack:runtime-template && npm run pack:runtime-optimize && npm run pack:runtime-module && npm run pack:runtime-view && npm run pack:runtime-router && npm run pack:runtime-scheduler && npm run pack:runtime-app && npm run pack:runtime-core && npm run pack:core && npm run pack:nodomx && npm run pack:nd && npm run pack:nd:rollup && npm run pack:dev-server && npm run pack:create",
    "release:publish": "node ./scripts/release/publish.mjs",
    "package:extension": "npm run package -w nodomx-nd-vscode"
  }
}
